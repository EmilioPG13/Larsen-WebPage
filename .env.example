# Copy to `.env` (or `.env.local`) and fill in. All client-exposed vars must be prefixed with VITE_.

# Backend API base URL (Express server). Defaults to http://localhost:3001/api when unset.
VITE_API_URL=http://localhost:3001/api

# EmailJS — powers quote-form lead notifications (https://www.emailjs.com/).
# When all three are set, the quote form emails a notification in addition to
# (best-effort) storing the lead in the backend. Leave blank to disable EmailJS.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
